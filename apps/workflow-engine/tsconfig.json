{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "vitest/globals"],
    "paths": {
      "@workspace/backend/*": ["../../packages/backend/convex/*"],
      "@/*": ["./src/*"]
    },
    "noEmit": true
  },
  "include": ["src/**/*", "types/**/*.ts"],
  "exclude": ["node_modules"]
}